{
  "name": "vitera-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:wounds": "turbo dev --filter=@vitera/backend --filter=@vitera/wounds --filter=@vitera/portal",
    "dev:bones": "turbo dev --filter=@vitera/backend --filter=@vitera/bones --filter=@vitera/portal",
    "dev:hq": "turbo dev --filter=@vitera/backend --filter=@vitera/hq --filter=@vitera/portal",
    "dev:intimacy": "turbo dev --filter=@vitera/backend --filter=@vitera/intimacy --filter=@vitera/portal",
    "dev:portal": "turbo dev --filter=@vitera/backend --filter=@vitera/portal",
    "dev:portal-only": "turbo dev --filter=@vitera/portal",
    "dev:women-healing-room": "turbo dev --filter=@vitera/women-healing-room",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "rm -rf apps/*/.next",
    "clean:hq": "rm -rf apps/hq/.next",
    "clean:portal": "rm -rf apps/portal/.next",
    "clean:wounds": "rm -rf apps/wounds/.next",
    "clean:bones": "rm -rf apps/bones/.next",
    "clean:intimacy": "rm -rf apps/intimacy/.next",
    "db:generate": "pnpm -C backend exec prisma generate",
    "db:migrate": "pnpm -C backend db:migrate",
    "db:push": "pnpm -C backend db:push",
    "db:deploy": "pnpm -C backend db:deploy",
    "db:seed": "pnpm -C backend db:seed",
    "db:migrate-admins": "pnpm -C backend exec tsx prisma/migrate-admins.ts",
    "db:migrate-staging-to-local": "pnpm -C backend exec tsx prisma/migrate-staging-to-local.ts",
    "db:studio": "pnpm -C backend db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.0"
}
