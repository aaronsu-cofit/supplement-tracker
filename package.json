{
  "name": "vitera-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:wounds": "turbo dev --filter=@vitera/backend --filter=@vitera/wounds ",
    "dev:bones": "turbo dev --filter=@vitera/backend --filter=@vitera/bones ",
    "dev:hq": "turbo dev --filter=@vitera/backend --filter=@vitera/hq",
    "dev:intimacy": "turbo dev --filter=@vitera/backend --filter=@vitera/intimacy ",
    "dev:portal": "turbo dev --filter=@vitera/backend ",
    "dev:portal-only": "turbo dev --filter=@vitera/portal",
    "dev:women-healing-room": "turbo dev --filter=@vitera/women-healing-room",
    "dev:period-tracker": "turbo dev --filter=@vitera/backend --filter=@vitera/period-tracker ",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "rm -rf apps/*/.next apps/period-tracker/dist",
    "clean:hq": "rm -rf apps/hq/.next",
    "clean:portal": "rm -rf apps/portal/.next",
    "clean:wounds": "rm -rf apps/wounds/.next",
    "clean:bones": "rm -rf apps/bones/.next",
    "clean:intimacy": "rm -rf apps/intimacy/.next",
    "clean:period-tracker": "rm -rf apps/period-tracker/dist",
    "db:generate": "pnpm -C backend exec prisma generate",
    "db:migrate": "pnpm -C backend db:migrate",
    "db:push": "pnpm -C backend db:push",
    "db:deploy": "pnpm -C backend db:deploy",
    "db:seed": "pnpm -C backend db:seed",
    "db:reset": "pnpm -C backend db:reset",
    "db:migrate-admins": "pnpm -C backend exec tsx prisma/migrate-admins.ts",
    "db:sync-staging-full": "./scripts/sync-staging-db-to-local.sh",
    "db:studio": "pnpm -C backend db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.0"
}
