{
  "name": "vitera-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:wounds": "turbo dev --filter=@vitera/backend --filter=@vitera/wounds --filter=@vitera/portal",
    "dev:bones": "turbo dev --filter=@vitera/backend --filter=@vitera/bones --filter=@vitera/portal",
    "dev:supplements": "turbo dev --filter=@vitera/backend --filter=@vitera/supplements --filter=@vitera/portal",
    "dev:hq": "turbo dev --filter=@vitera/backend --filter=@vitera/hq",
    "dev:intimacy": "turbo dev --filter=@vitera/backend --filter=@vitera/intimacy --filter=@vitera/portal",
    "dev:portal": "turbo dev --filter=@vitera/backend --filter=@vitera/portal",
    "dev:portal-only": "turbo dev --filter=@vitera/portal",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.0"
}
