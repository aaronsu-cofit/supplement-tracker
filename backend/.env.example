# Database
# Local dev:
# POSTGRES_URL=postgresql://aaron_su@localhost:5432/vitera_dev
#
# Staging (GCP Cloud SQL via Cloud SQL Auth Proxy on localhost:5433):
# POSTGRES_URL=postgresql://USER:PASS@127.0.0.1:5433/vitera_staging
#
# Staging (GCP Cloud SQL Direct — public IP, requires authorized network or SSL):
# POSTGRES_URL=postgresql://USER:PASS@<CLOUD_SQL_PUBLIC_IP>:5432/vitera_staging?sslmode=require
POSTGRES_URL=postgresql://user:pass@host/dbname

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AI
GEMINI_API_KEY=your-gemini-api-key
ADK_URL=https://adk-service-xxx-uc.a.run.app
ADK_API_KEY=your-adk-api-key

# LINE
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
# Database record ID of the LINE OA corresponding to this webhook's LINE_CHANNEL_ACCESS_TOKEN
LINE_OA_ID=1

# LIFF URLs — used in LINE postback replies
LIFF_URL_MAIN=https://liff.line.me/your-liff-id
LIFF_URL_WOUNDS=https://liff.line.me/your-wounds-liff-id

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-portal.vercel.app,https://your-wounds.vercel.app

# Cookie Domain
# For cross-subdomain auth (e.g., .cofit.me for vitera-wounds.cofit.me & vitera-hq.cofit.me)
# COOKIE_DOMAIN=.cofit.me

# Server
PORT=8080
NODE_ENV=production
