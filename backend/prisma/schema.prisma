// Inbound LINE text that didn't match any Intent rule. Surfaced in HQ
// so ops can see what real users are asking and convert frequent
// questions into new Intent rules. Updated with the LLM reply (or
// error) so the full Q/A is auditable.
model UnmatchedIntent {
  id         Int      @id @default(autoincrement())
  user_id    String   @db.VarChar(64)
  oa_id      Int
  product_id String?  @db.VarChar(30)
  agent_id   String?  @db.VarChar(100)
  message    String   @db.VarChar(2000)
  reply      String?
  skill_key  String?  @db.VarChar(100)
  model      String?  @db.VarChar(100)
  latency_ms Int?
  error      String?
  resolved   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([oa_id, created_at(sort: Desc)], name: "idx_unmatched_intents_oa_created")
  @@index([resolved, created_at(sort: Desc)], name: "idx_unmatched_intents_resolved")
  @@index([user_id, created_at(sort: Desc)], name: "idx_unmatched_intents_user_created")
  @@map("unmatched_intents")
}

enum ReliefType {
  BREATHING
  BODY_SCAN
  SLEEP_QUOTES
}

// ============================================
// Period Tracking Models
// ============================================

// MenstrualCycle stores user's menstrual cycle settings and onboarding state
model MenstrualCycle {
  id             String   @id @default(cuid())
  user_id        String   @unique @db.VarChar(64)
  cycle_length   Int      @default(28)  // Average cycle length in days
  period_length  Int      @default(5)   // Average period length in days
  onboarding_done Boolean @default(false) // Whether user completed onboarding
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("menstrual_cycles")
}

// Period represents a user's menstrual period record
model Period {
  id        String   @id @default(cuid())
  user_id   String   @db.VarChar(64)
  startDate DateTime
  endDate   DateTime?
  notes     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_periods_user")
  @@index([startDate], name: "idx_periods_startDate")
  @@map("menstrual_periods")
}

// DailyLog stores detailed daily records for period tracking (symptoms, emotions, flow, etc.)
model DailyLog {
  id        String   @id @default(cuid())
  user_id   String   @db.VarChar(64)
  date      DateTime
  data      Json     // Stores symptoms, emotions, flow, blood color, clots, pbacLogs
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date], name: "uq_daily_logs_user_date")
  @@index([user_id], name: "idx_daily_logs_user")
  @@map("menstrual_daily_logs")
}
