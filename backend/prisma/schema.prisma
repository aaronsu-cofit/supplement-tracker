generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id            String    @id @db.VarChar(64)
  email         String?   @unique @db.VarChar(200)
  password_hash String?   @db.VarChar(200)
  display_name  String?   @db.VarChar(200)
  picture_url   String?
  auth_provider String    @db.VarChar(20)
  role          String    @default("user") @db.VarChar(20)
  timezone      String    @default("Asia/Taipei") @db.VarChar(50)
  created_at    DateTime  @default(now())
  // Soft-delete marker. NULL = active. See lib/userDeletion.ts for the
  // soft-delete + hard-purge SOP. All per-user platform tables cascade
  // on hard DELETE so a single users-row delete wipes the trail.
  deleted_at    DateTime?

  supplements           Supplement[]
  check_ins             CheckIn[]
  wounds                Wound[]
  wound_logs            WoundLog[]
  foot_assessments      FootAssessment[]
  foot_images           FootImage[]
  shoe_images           ShoeImage[]
  intimacy_assessments  IntimacyAssessment[]
  enrollments           Enrollment[]
  diary_entries         DiaryEntry[]
  relief_sessions       ReliefSession[]
  assessment_results    AssessmentResult[]
  // Platform tables (LINE OA / DTx layer). Cascade on user delete for
  // PII compliance; back-relations declared here so Prisma accepts the
  // ON DELETE CASCADE in the migration.
  mission_assignments   MissionAssignment[]
  mission_daily_logs    MissionDailyLog[]
  user_mission_settings UserMissionSetting[]
  user_attributes       UserAttribute[]
  user_streaks          UserStreak[]
  user_badges           UserBadge[]
  user_journey_phases   UserJourneyPhase[]
  message_logs          MessageLog[]
  message_deliveries    MessageDelivery[]
  engagement_events     EngagementEvent[]
  unmatched_intents     UnmatchedIntent[]
  user_menu_assignments UserMenuAssignment[]
  user_oa_sessions      UserOaSession[]
  // Period tracking
  periods               Period[]
  menstrual_cycle       MenstrualCycle?
  daily_logs            DailyLog[]

  @@index([deleted_at], name: "idx_users_deleted_at")
  @@map("users")
}

// Admin users: HQ backend access control
// Separate from Patient Users to maintain clear separation of concerns.
// Roles: 'admin' (basic management), 'superadmin' (full system access)
model Admin {
  id            String    @id @db.VarChar(64)
  email         String    @unique @db.VarChar(200)
  password_hash String    @db.VarChar(200)
  display_name  String?   @db.VarChar(200)
  picture_url   String?
  auth_provider String    @default("email") @db.VarChar(20)  // "email" or "line"
  role          String    @default("admin") @db.VarChar(20)  // "admin" or "superadmin"
  timezone      String    @default("Asia/Taipei") @db.VarChar(50)
  created_at    DateTime  @default(now())
  deleted_at    DateTime?

  @@index([deleted_at], name: "idx_admins_deleted_at")
  @@map("admins")
}

model Supplement {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  name        String   @db.VarChar(200)
  dosage      String?  @db.VarChar(100)
  frequency   String   @default("daily") @db.VarChar(50)
  time_of_day String   @default("morning") @db.VarChar(20)
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user      User      @relation(fields: [user_id], references: [id])
  check_ins CheckIn[]

  @@index([user_id], name: "idx_supplements_user")
  @@map("supplements")
}

model CheckIn {
  id            Int      @id @default(autoincrement())
  user_id       String   @db.VarChar(64)
  supplement_id Int
  checked_at    DateTime @default(now())
  date          DateTime @default(now()) @db.Date

  user       User       @relation(fields: [user_id], references: [id])
  supplement Supplement @relation(fields: [supplement_id], references: [id], onDelete: Cascade)

  @@index([user_id, date], name: "idx_checkins_user_date")
  @@map("check_ins")
}

model Wound {
  id             Int       @id @default(autoincrement())
  user_id        String    @db.VarChar(64)
  name           String?   @db.VarChar(200)
  location       String?   @db.VarChar(200)
  date_of_injury DateTime? @db.Date
  display_name   String?   @db.VarChar(200)
  picture_url    String?
  wound_type     String?   @db.VarChar(50)
  body_location  String?   @db.VarChar(100)
  status         String    @default("active") @db.VarChar(20)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  user       User       @relation(fields: [user_id], references: [id])
  wound_logs WoundLog[]

  @@index([user_id], name: "idx_wounds_user")
  @@map("wounds")
}

model WoundLog {
  id                    Int      @id @default(autoincrement())
  wound_id              Int
  user_id               String   @db.VarChar(64)
  image_data            String?
  nrs_pain_score        Int      @default(0)
  symptoms              String?
  ai_assessment_summary String?
  ai_status_label       String?  @db.VarChar(100)
  logged_at             DateTime @default(now())
  date                  DateTime @default(now()) @db.Date

  wound Wound @relation(fields: [wound_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id])

  @@index([user_id, date], name: "idx_wound_logs_user_date")
  @@map("wound_logs")
}

model FootAssessment {
  id             Int      @id @default(autoincrement())
  user_id        String   @db.VarChar(64)
  pain_locations String?
  nrs_pain_score Int      @default(0)
  steps_count    Int      @default(0)
  standing_hours Float    @default(0)
  date           DateTime @default(now()) @db.Date

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, date], name: "idx_foot_assessments_user_date")
  @@map("foot_assessments")
}

model FootImage {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  image_data  String?
  ai_severity String?  @db.VarChar(50)
  ai_summary  String?
  ai_details  Json?
  logged_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id], name: "idx_foot_images_user")
  @@map("foot_images")
}

model ShoeImage {
  id              Int      @id @default(autoincrement())
  user_id         String   @db.VarChar(64)
  image_data      String?
  ai_risk_level   String?  @db.VarChar(50)
  ai_wear_pattern String?  @db.VarChar(100)
  ai_summary      String?
  ai_details      Json?
  logged_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id], name: "idx_shoe_images_user")
  @@map("shoe_images")
}

model IntimacyAssessment {
  id              Int      @id @default(autoincrement())
  user_id         String   @db.VarChar(64)
  gender          String?  @db.VarChar(20)
  primary_concern String?  @db.VarChar(200)
  assessment_data Json?
  ai_summary      String?
  created_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id], name: "idx_intimacy_assessments_user")
  @@map("intimacy_assessments")
}

model Module {
  id           String   @id @db.VarChar(50)
  name_zh      String?  @db.VarChar(100)
  name_en      String?  @db.VarChar(100)
  description  String?
  is_active    Boolean  @default(true)
  sort_order   Int      @default(0)
  external_url String?
  icon_type    String?  @db.VarChar(50)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("modules")
}

model LineOA {
  id                        Int      @id @default(autoincrement())
  name                      String   @db.VarChar(200)
  description               String?
  channel_access_token      String   @db.VarChar(500)
  channel_secret            String?  @db.VarChar(200)
  line_destination_id       String?  @db.VarChar(64)
  default_agent_id          String   @default("ai-expert") @db.VarChar(100)
  ai_skill_platform_url     String?  @db.VarChar(500)
  ai_skill_platform_api_key String?  @db.VarChar(500)
  product_id                String?  @db.VarChar(30)
  is_active                 Boolean  @default(true)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  richMenuTemplates LineOARichMenuTemplate[]
  scenarios         CoBlocksScenario[]
  // Legacy single-product binding. Kept for backwards compat during the
  // N:N rollout (step 1+2 of the migration plan); will be dropped in
  // step 5 once code is fully cut over to oa_products + UserOaSession.
  product           Product?                 @relation(fields: [product_id], references: [id], onDelete: SetNull)
  // N:N binding (step 1+ of the migration plan). Treat this as the
  // canonical relation going forward; `product` above is a transitional
  // shim. is_default marks the product to use when a user has no
  // UserOaSession yet.
  oa_products       OaProduct[]
  user_sessions     UserOaSession[]

  @@index([line_destination_id], name: "idx_line_oa_destination")
  @@index([product_id], name: "idx_line_oa_product")
  @@map("line_oa")
}

// A "Product" is a shareable configuration bundle (content library,
// missions, intent rules, scenarios, badges, journeys) that multiple
// LINE OAs can bind to. Lets ops write config once and deploy across
// multiple channels.
model Product {
  id          String   @id @default(cuid()) @db.VarChar(30)
  name        String   @db.VarChar(200)
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  oas               LineOA[]
  content_items     ContentItem[]
  intent_rules      IntentRule[]
  mission_templates MissionTemplate[]
  badge_templates   BadgeTemplate[]
  user_streaks      UserStreak[]
  journey_templates JourneyTemplate[]
  // N:N: every OA that has this product in its bound set, plus the
  // per-user "current product" sessions pointing here.
  oa_products       OaProduct[]
  user_sessions     UserOaSession[]

  @@map("products")
}

// N:N junction: which products are bound to which OAs. is_default
// marks the product to fall back to when a user has no UserOaSession
// for this OA yet (partial unique index in the migration enforces "at
// most one default per OA"). sort_order is for HQ display.
model OaProduct {
  oa_id      Int
  product_id String   @db.VarChar(30)
  is_default Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  oa      LineOA  @relation(fields: [oa_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([oa_id, product_id])
  @@index([product_id], name: "idx_oa_products_product")
  @@map("oa_products")
}

// Per-(user, oa) pointer to the product context that user is currently
// in. Read on every inbound webhook by resolveCurrentProduct(); writes
// happen on first-touch (default product) and on explicit switch
// (intent rule action `switch_product`, postback, etc).
model UserOaSession {
  user_id            String   @db.VarChar(64)
  oa_id              Int
  current_product_id String   @db.VarChar(30)
  last_active_at     DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  oa      LineOA  @relation(fields: [oa_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [current_product_id], references: [id], onDelete: Cascade)

  @@id([user_id, oa_id])
  @@index([oa_id, current_product_id], name: "idx_user_oa_sessions_oa_product")
  @@map("user_oa_sessions")
}

// Shareable content items owned by a Product. `key` is a product-scoped
// slug used by flows/push nodes to reference content by name instead of
// hard-coding text. `type` indicates rendering form: 'text' (plain string),
// 'flex' (LINE flex JSON in metadata), 'card' (structured card in metadata).
// Keeps text copy and structured cards out of the scenario JSON so ops can
// edit content without touching flows.
model ContentItem {
  id         String   @id @default(cuid()) @db.VarChar(30)
  product_id String   @db.VarChar(30)
  key        String   @db.VarChar(100)
  type       String   @default("text") @db.VarChar(50)
  title      String?  @db.VarChar(200)
  body       String?  @db.Text
  metadata   Json?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, key])
  @@index([product_id], name: "idx_content_items_product")
  @@map("content_items")
}

// Product-scoped intent rules: when a text message arrives on an OA bound
// to this product, rules are evaluated in priority order (lower = first).
// First match wins and its action runs; no match falls through to the AI
// agent. `match_type`: 'keyword' (substring, case-insensitive) for now;
// 'regex'/'exact' reserved. `patterns` is a JSON array of strings.
// `action_type`:
//   - 'reply_content': config = { content_key }
//   - 'set_attribute': config = { key, value, reply_content_key? }
model IntentRule {
  id            String   @id @default(cuid()) @db.VarChar(30)
  product_id    String   @db.VarChar(30)
  name          String   @db.VarChar(200)
  priority      Int      @default(100)
  match_type    String   @default("keyword") @db.VarChar(20)
  patterns      Json
  action_type   String   @db.VarChar(50)
  action_config Json
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, is_active, priority], name: "idx_intent_rules_product_pri")
  @@map("intent_rules")
}

// Product-scoped mission blueprints. `key` is the product-scoped slug
// that intent rules / flow nodes reference. Three axes of "depth":
//   - progress_target: multi-step missions (target > 1 → user increments
//     before completion)
//   - auto_complete_on_attribute: { attribute_key, match_value? } — when
//     user's attribute is set (optionally to exact value), pending
//     assignments for this template auto-complete
//   - on_complete_actions: array run on completion regardless of trigger
//     path. Supported: set_attribute, assign_mission (chain). Keeps
//     rewards declarative on the template so any path completes the same way.
model MissionTemplate {
  id                         String  @id @default(cuid()) @db.VarChar(30)
  product_id                 String  @db.VarChar(30)
  key                        String  @db.VarChar(100)
  name                       String  @db.VarChar(200)
  description                String?
  progress_target            Int     @default(1)
  auto_complete_on_attribute Json?
  on_complete_actions        Json    @default("[]")
  notify_content_key         String? @db.VarChar(100)

  // ── Habit-tracker extensions ──────────────────────────────────────
  // mission_type:
  //   one_shot          — existing default. Completes once, terminal.
  //   binary_daily      — yes/no per day. Log row marks completed.
  //   quantitative_daily — target with unit (e.g. "2000cc 水"). Log
  //                       row accumulates value until >= daily_target.
  //   checklist_daily   — fixed subtasks. Completed when all subtasks
  //                       ticked for the day.
  // For daily types, MissionAssignment stays pending permanently (it
  // represents "subscribed to this habit"); MissionDailyLog holds
  // per-day progress.
  mission_type String  @default("one_shot") @db.VarChar(30)
  // frequency describes the cadence expectation — UI grouping hint.
  // 'once' for one_shot; 'daily' / 'weekly' / 'monthly' for recurring.
  frequency    String  @default("once") @db.VarChar(20)
  // quantitative_daily settings
  daily_target Int?
  unit         String? @db.VarChar(30)
  step_value   Int?
  // checklist_daily subtasks: array of { key, label }
  subtasks     Json?
  // Display grouping in LIFF / admin
  category     String? @db.VarChar(50)
  // Optional URL opened from a mission card button (LIFF / web form).
  // When set, the checklist flex button becomes a uri action instead
  // of a postback; the LIFF then reports completion via /api/me/...
  action_url   String?
  // Reminder settings: { enabled: bool, time: "HH:MM" }. Scheduler
  // will eventually read this; for now just stored.
  reminder     Json?

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product     Product             @relation(fields: [product_id], references: [id], onDelete: Cascade)
  assignments MissionAssignment[]
  daily_logs  MissionDailyLog[]

  @@unique([product_id, key])
  @@index([product_id], name: "idx_mission_templates_product")
  @@map("mission_templates")
}

// Per-user overrides for a mission template's personalisable fields.
// Currently supports a custom daily_target (e.g. user sets 5 cups of
// water where the template default is 8). Null means "inherit from
// template". Additional override fields — custom reminder, disabled
// flag, step_value — can be added here without migrating existing
// users. Deleted when the assignment is removed.
model UserMissionSetting {
  id               Int      @id @default(autoincrement())
  user_id          String   @db.VarChar(64)
  template_id      String   @db.VarChar(30)
  daily_target     Int?
  reminder_enabled Boolean?
  reminder_time    String?  @db.VarChar(10)
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id])
  @@index([user_id], name: "idx_user_mission_setting_user")
  @@map("user_mission_settings")
}

// Per-day completion log for habit-style missions. One row per
// (user, template, date). For binary_daily, `completed` flips true
// once the user taps "done". For quantitative_daily, `value`
// increments toward template.daily_target; completed flips to true
// the first time value hits target (not on later increments). For
// checklist_daily, `subtask_state` holds { key: true/false }; completed
// flips true when all subtasks are ticked.
//
// The `completed_at` timestamp is only written on the transition from
// false → true; later writes don't move it. Used to distinguish "newly
// completed today" (fire hooks) from "already completed earlier today"
// (no-op) so on_complete_actions / notify only fire once per day.
model MissionDailyLog {
  id            Int       @id @default(autoincrement())
  user_id       String    @db.VarChar(64)
  template_id   String    @db.VarChar(30)
  date          DateTime  @db.Date
  completed     Boolean   @default(false)
  skipped       Boolean   @default(false)
  value         Int       @default(0)
  subtask_state Json?
  note          String?   @db.VarChar(500)
  completed_at  DateTime?
  updated_at    DateTime  @updatedAt

  template MissionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id, date])
  @@index([user_id, date], name: "idx_mission_daily_log_user_date")
  @@index([template_id, date], name: "idx_mission_daily_log_template_date")
  @@map("mission_daily_logs")
}

// Per-user mission instance. Status transitions: pending → completed
// (or pending → abandoned). A user can only have one active (non-
// completed/abandoned) assignment per template at a time; re-assign
// after completion creates a new row so we keep history.
// progress_target is snapshotted from the template at assignment time
// so later edits to the template don't change an in-flight assignment.
model MissionAssignment {
  id               String    @id @default(cuid()) @db.VarChar(30)
  user_id          String    @db.VarChar(64)
  template_id      String    @db.VarChar(30)
  status           String    @default("pending") @db.VarChar(20)
  progress_current Int       @default(0)
  progress_target  Int       @default(1)
  assigned_at      DateTime  @default(now())
  completed_at     DateTime?

  template MissionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status], name: "idx_mission_assignments_user_status")
  @@index([template_id], name: "idx_mission_assignments_template")
  @@map("mission_assignments")
}

// Per-(product, user, streak_key) counter of consecutive days the user
// triggered the streak event. last_occurred_on is a date (no time) in
// the user's timezone; `incrementStreak` in lib/gamification.ts handles
// the "already counted today / continuing yesterday / resetting" logic.
model UserStreak {
  id               Int       @id @default(autoincrement())
  product_id       String    @db.VarChar(30)
  user_id          String    @db.VarChar(64)
  streak_key       String    @db.VarChar(100)
  count_current    Int       @default(0)
  count_best       Int       @default(0)
  last_occurred_on DateTime? @db.Date
  updated_at       DateTime  @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id, streak_key])
  @@index([product_id, streak_key], name: "idx_user_streaks_product_key")
  @@map("user_streaks")
}

// Product-scoped badge blueprints. `criteria` describes how a badge is
// earned:
//   { type: 'streak_reached', streak_key, threshold }
//   { type: 'mission_completed', mission_key }
// Evaluation happens after streak increments and mission completions
// (see lib/gamification.ts).
model BadgeTemplate {
  id                 String   @id @default(cuid()) @db.VarChar(30)
  product_id         String   @db.VarChar(30)
  key                String   @db.VarChar(100)
  name               String   @db.VarChar(200)
  description        String?
  // Stored as TEXT to fit: emoji (1-4 chars), URL (~100 chars), or
  // data: URI (base64 image, can be tens of KB).
  icon               String?  @db.Text
  criteria           Json
  // Same semantics as MissionTemplate.notify_content_key — sends the
  // referenced content item when the badge is awarded (once, since
  // badges are unique-per-user).
  notify_content_key String?  @db.VarChar(100)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  product     Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user_badges UserBadge[]

  @@unique([product_id, key])
  @@index([product_id], name: "idx_badge_templates_product")
  @@map("badge_templates")
}

// Earned-badge records. Unique on (user_id, template_id) so each badge
// is awarded at most once per user.
model UserBadge {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  template_id String   @db.VarChar(30)
  earned_at   DateTime @default(now())

  template BadgeTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id])
  @@index([user_id], name: "idx_user_badges_user")
  @@index([template_id], name: "idx_user_badges_template")
  @@map("user_badges")
}

// Product-scoped journey blueprint. `phases` is an ordered array of
// { key, name, description?, icon? }. `transitions` is an array of
// { from_phase?, to_phase, trigger } where from_phase undefined means
// "from any phase (including no phase)". Trigger types: mission_completed
// { mission_key }, attribute_equals { attribute_key, value },
// badge_earned { badge_key }. Evaluated after the event fires.
model JourneyTemplate {
  id          String   @id @default(cuid()) @db.VarChar(30)
  product_id  String   @db.VarChar(30)
  key         String   @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?
  phases      Json
  transitions Json
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, key])
  @@index([product_id], name: "idx_journey_templates_product")
  @@map("journey_templates")
}

// Full conversation log: every inbound user message and every outbound
// bot message goes in here. Exists alongside `engagement_events` (which
// tracks semantic events like intent_matched/badge_earned) — this table
// is specifically "what was actually said, in both directions".
// `content_text` stores plain text / altText / postback data for quick
// preview; `content_json` stores the full structured payload (flex
// bubbles, sticker ids, etc). `source` tags what triggered an outbound:
// 'follow_reply' | 'postback_reply' | 'intent' | 'ai_agent' |
// 'scheduler_push' | 'scheduler_ai'. `source_ref` optionally carries
// rule id / scenario:node / agent id for debugging.
model MessageLog {
  id           Int      @id @default(autoincrement())
  oa_id        Int
  user_id      String   @db.VarChar(64)
  direction    String   @db.VarChar(10)
  type         String   @db.VarChar(20)
  content_text String?  @db.Text
  content_json Json?
  source       String?  @db.VarChar(30)
  source_ref   String?  @db.VarChar(200)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([oa_id, created_at], name: "idx_message_log_oa_time")
  @@index([user_id, created_at], name: "idx_message_log_user_time")
  @@index([oa_id, user_id, created_at], name: "idx_message_log_oa_user_time")
  @@map("message_log")
}

// Per-(product, user, journey_key) current phase. Unique on the tuple
// so a user is in exactly one phase per journey at a time.
model UserJourneyPhase {
  id          Int      @id @default(autoincrement())
  product_id  String   @db.VarChar(30)
  user_id     String   @db.VarChar(64)
  journey_key String   @db.VarChar(100)
  phase_key   String   @db.VarChar(100)
  entered_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id, journey_key])
  @@index([product_id, journey_key, phase_key], name: "idx_user_journey_phase")
  @@map("user_journey_phases")
}

// Arbitrary per-user key/value attributes (e.g. primary_concern,
// life_stage, onboarding_done, allergies). Set during onboarding, by
// intent classifier, or by mission completion. Consumed by flow
// routing, content selection, personalization.
// Multi-product safety: this table is NOT scoped by product_id, so a
// user bound to two products with the same `key` shares the value
// across both. Cross-product collisions must be prevented with a key
// prefix convention — see backend/docs/db-conventions.md ("UserAttribute
// keys"). Common product-specific prefixes already in use:
//   period_*  → 月經週期 product
//   nutri_*   → 營養 product
// Generic keys (life_stage, primary_concern) are intentionally shared.
model UserAttribute {
  id      Int      @id @default(autoincrement())
  user_id String   @db.VarChar(64)
  key     String   @db.VarChar(100)
  value   String?
  set_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, key])
  @@index([user_id], name: "idx_user_attributes_user")
  @@index([key, value], name: "idx_user_attributes_key_value")
  @@map("user_attributes")
}

model LineOARichMenuTemplate {
  id                Int      @id @default(autoincrement())
  oa_id             Int
  name              String   @db.VarChar(200)
  zones             Json
  line_rich_menu_id String?  @db.VarChar(100)
  is_active         Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  oa LineOA @relation(fields: [oa_id], references: [id], onDelete: Cascade)

  @@index([oa_id], name: "idx_rich_menu_templates_oa")
  @@map("line_oa_rich_menu_template")
}

model CoBlocksScenario {
  id         String   @id @default(cuid())
  oa_id      Int
  name       String
  flow_nodes Json     @default("[]")
  flow_edges Json     @default("[]")
  is_active  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  oa          LineOA       @relation(fields: [oa_id], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@index([oa_id], name: "idx_coblocks_scenarios_oa")
  @@index([is_active], name: "idx_coblocks_scenarios_active")
  @@map("coblocks_scenarios")
}

model Enrollment {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  scenario_id String   @db.VarChar(30)
  enrolled_at DateTime @default(now())
  status      String   @default("active") @db.VarChar(20)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user     User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  scenario CoBlocksScenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)

  @@unique([user_id, scenario_id])
  @@index([user_id], name: "idx_enrollment_user")
  @@index([scenario_id, status], name: "idx_enrollment_scenario_status")
  @@map("enrollments")
}

model UserMenuAssignment {
