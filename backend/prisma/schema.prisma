generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id                    String                 @id @db.VarChar(64)
  email                 String?                @unique @db.VarChar(200)
  password_hash         String?                @db.VarChar(200)
  display_name          String?                @db.VarChar(200)
  picture_url           String?
  auth_provider         String                 @db.VarChar(20)
  role                  String                 @default("user") @db.VarChar(20)
  created_at            DateTime               @default(now())
  timezone              String                 @default("Asia/Taipei") @db.VarChar(50)
  deleted_at            DateTime?
  assessment_results    AssessmentResult[]
  check_ins             CheckIn[]
  diary_entries         DiaryEntry[]
  engagement_events     EngagementEvent[]
  enrollments           Enrollment[]
  foot_assessments      FootAssessment[]
  foot_images           FootImage[]
  intimacy_assessments  IntimacyAssessment[]
  menstrual_cycles      menstrual_cycles?
  menstrual_daily_logs  menstrual_daily_logs[]
  menstrual_periods     menstrual_periods[]
  message_deliveries    MessageDelivery[]
  message_logs          MessageLog[]
  mission_assignments   MissionAssignment[]
  mission_daily_logs    MissionDailyLog[]
  relief_sessions       ReliefSession[]
  shoe_images           ShoeImage[]
  supplements           Supplement[]
  unmatched_intents     UnmatchedIntent[]
  user_attributes       UserAttribute[]
  user_badges           UserBadge[]
  user_journey_phases   UserJourneyPhase[]
  user_menu_assignments UserMenuAssignment[]
  user_mission_settings UserMissionSetting[]
  user_oa_sessions      user_oa_sessions[]
  user_streaks          UserStreak[]
  wound_logs            WoundLog[]
  wounds                Wound[]

  @@index([deleted_at], map: "idx_users_deleted_at")
  @@map("users")
}

model Admin {
  id            String    @id @db.VarChar(64)
  email         String    @unique @db.VarChar(200)
  password_hash String    @db.VarChar(200)
  display_name  String?   @db.VarChar(200)
  picture_url   String?
  auth_provider String    @default("email") @db.VarChar(20)
  role          String    @default("admin") @db.VarChar(20)
  timezone      String    @default("Asia/Taipei") @db.VarChar(50)
  created_at    DateTime  @default(now())
  deleted_at    DateTime?

  @@index([deleted_at], map: "idx_admins_deleted_at")
  @@map("admins")
}

model Supplement {
  id          Int       @id @default(autoincrement())
  user_id     String    @db.VarChar(64)
  name        String    @db.VarChar(200)
  dosage      String?   @db.VarChar(100)
  frequency   String    @default("daily") @db.VarChar(50)
  time_of_day String    @default("morning") @db.VarChar(20)
  notes       String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  check_ins   CheckIn[]
  user        User      @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_supplements_user")
  @@map("supplements")
}

model CheckIn {
  id            Int        @id @default(autoincrement())
  user_id       String     @db.VarChar(64)
  supplement_id Int
  checked_at    DateTime   @default(now())
  date          DateTime   @default(now()) @db.Date
  supplement    Supplement @relation(fields: [supplement_id], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [user_id], references: [id])

  @@index([user_id, date], map: "idx_checkins_user_date")
  @@map("check_ins")
}

model Wound {
  id             Int        @id @default(autoincrement())
  user_id        String     @db.VarChar(64)
  name           String?    @db.VarChar(200)
  location       String?    @db.VarChar(200)
  date_of_injury DateTime?  @db.Date
  display_name   String?    @db.VarChar(200)
  picture_url    String?
  wound_type     String?    @db.VarChar(50)
  body_location  String?    @db.VarChar(100)
  status         String     @default("active") @db.VarChar(20)
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  wound_logs     WoundLog[]
  user           User       @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_wounds_user")
  @@map("wounds")
}

model WoundLog {
  id                    Int      @id @default(autoincrement())
  wound_id              Int
  user_id               String   @db.VarChar(64)
  image_data            String?
  nrs_pain_score        Int      @default(0)
  symptoms              String?
  ai_assessment_summary String?
  ai_status_label       String?  @db.VarChar(100)
  logged_at             DateTime @default(now())
  date                  DateTime @default(now()) @db.Date
  user                  User     @relation(fields: [user_id], references: [id])
  wound                 Wound    @relation(fields: [wound_id], references: [id], onDelete: Cascade)

  @@index([user_id, date], map: "idx_wound_logs_user_date")
  @@map("wound_logs")
}

model FootAssessment {
  id             Int      @id @default(autoincrement())
  user_id        String   @db.VarChar(64)
  pain_locations String?
  nrs_pain_score Int      @default(0)
  steps_count    Int      @default(0)
  standing_hours Float    @default(0)
  date           DateTime @default(now()) @db.Date
  user           User     @relation(fields: [user_id], references: [id])

  @@index([user_id, date], map: "idx_foot_assessments_user_date")
  @@map("foot_assessments")
}

model FootImage {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  image_data  String?
  ai_severity String?  @db.VarChar(50)
  ai_summary  String?
  ai_details  Json?
  logged_at   DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_foot_images_user")
  @@map("foot_images")
}

model ShoeImage {
  id              Int      @id @default(autoincrement())
  user_id         String   @db.VarChar(64)
  image_data      String?
  ai_risk_level   String?  @db.VarChar(50)
  ai_wear_pattern String?  @db.VarChar(100)
  ai_summary      String?
  ai_details      Json?
  logged_at       DateTime @default(now())
  user            User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_shoe_images_user")
  @@map("shoe_images")
}

model IntimacyAssessment {
  id              Int      @id @default(autoincrement())
  user_id         String   @db.VarChar(64)
  gender          String?  @db.VarChar(20)
  primary_concern String?  @db.VarChar(200)
  assessment_data Json?
  ai_summary      String?
  created_at      DateTime @default(now())
  user            User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_intimacy_assessments_user")
  @@map("intimacy_assessments")
}

model Module {
  id           String   @id @db.VarChar(50)
  name_zh      String?  @db.VarChar(100)
  name_en      String?  @db.VarChar(100)
  description  String?
  is_active    Boolean  @default(true)
  sort_order   Int      @default(0)
  external_url String?
  icon_type    String?  @db.VarChar(50)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("modules")
}

model LineOA {
  id                        Int                      @id @default(autoincrement())
  name                      String                   @db.VarChar(200)
  description               String?
  channel_access_token      String                   @db.VarChar(500)
  is_active                 Boolean                  @default(true)
  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @updatedAt
  channel_secret            String?                  @db.VarChar(200)
  line_destination_id       String?                  @db.VarChar(64)
  default_agent_id          String                   @default("ai-expert") @db.VarChar(100)
  ai_skill_platform_url     String?                  @db.VarChar(500)
  ai_skill_platform_api_key String?                  @db.VarChar(500)
  product_id                String?                  @db.VarChar(30)
  scenarios                 CoBlocksScenario[]
  product                   Product?                 @relation(fields: [product_id], references: [id])
  richMenuTemplates         LineOARichMenuTemplate[]
  oa_products               oa_products[]
  user_oa_sessions          user_oa_sessions[]

  @@index([line_destination_id], map: "idx_line_oa_destination")
  @@index([product_id], map: "idx_line_oa_product")
  @@map("line_oa")
}

model Product {
  id                String             @id @default(cuid()) @db.VarChar(30)
  name              String             @db.VarChar(200)
  description       String?
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  badge_templates   BadgeTemplate[]
  content_items     ContentItem[]
  intent_rules      IntentRule[]
  journey_templates JourneyTemplate[]
  oas               LineOA[]
  mission_templates MissionTemplate[]
  oa_products       oa_products[]
  user_oa_sessions  user_oa_sessions[]
  user_streaks      UserStreak[]

  @@map("products")
}

model ContentItem {
  id         String   @id @default(cuid()) @db.VarChar(30)
  product_id String   @db.VarChar(30)
  key        String   @db.VarChar(100)
  type       String   @default("text") @db.VarChar(50)
  title      String?  @db.VarChar(200)
  body       String?
  metadata   Json?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, key])
  @@index([product_id], map: "idx_content_items_product")
  @@map("content_items")
}

model IntentRule {
  id            String   @id @default(cuid()) @db.VarChar(30)
  product_id    String   @db.VarChar(30)
  name          String   @db.VarChar(200)
  priority      Int      @default(100)
  match_type    String   @default("keyword") @db.VarChar(20)
  patterns      Json
  action_type   String   @db.VarChar(50)
  action_config Json
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  product       Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, is_active, priority], map: "idx_intent_rules_product_pri")
  @@map("intent_rules")
}

model MissionTemplate {
  id                         String              @id @default(cuid()) @db.VarChar(30)
  product_id                 String              @db.VarChar(30)
  key                        String              @db.VarChar(100)
  name                       String              @db.VarChar(200)
  description                String?
  is_active                  Boolean             @default(true)
  created_at                 DateTime            @default(now())
  updated_at                 DateTime            @updatedAt
  progress_target            Int                 @default(1)
  auto_complete_on_attribute Json?
  on_complete_actions        Json                @default("[]")
  notify_content_key         String?             @db.VarChar(100)
  mission_type               String              @default("one_shot") @db.VarChar(30)
  frequency                  String              @default("once") @db.VarChar(20)
  daily_target               Int?
  unit                       String?             @db.VarChar(30)
  step_value                 Int?
  subtasks                   Json?
  category                   String?             @db.VarChar(50)
  action_url                 String?
  reminder                   Json?
  assignments                MissionAssignment[]
  daily_logs                 MissionDailyLog[]
  product                    Product             @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, key])
  @@index([product_id], map: "idx_mission_templates_product")
  @@map("mission_templates")
}

model UserMissionSetting {
  id               Int      @id @default(autoincrement())
  user_id          String   @db.VarChar(64)
  template_id      String   @db.VarChar(30)
  daily_target     Int?
  reminder_enabled Boolean?
  reminder_time    String?  @db.VarChar(10)
  updated_at       DateTime @updatedAt
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id])
  @@index([user_id], map: "idx_user_mission_setting_user")
  @@map("user_mission_settings")
}

model MissionDailyLog {
  id            Int             @id @default(autoincrement())
  user_id       String          @db.VarChar(64)
  template_id   String          @db.VarChar(30)
  date          DateTime        @db.Date
  completed     Boolean         @default(false)
  value         Int             @default(0)
  subtask_state Json?
  completed_at  DateTime?
  updated_at    DateTime        @updatedAt
  skipped       Boolean         @default(false)
  note          String?         @db.VarChar(500)
  template      MissionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id, date])
  @@index([user_id, date], map: "idx_mission_daily_log_user_date")
  @@index([template_id, date], map: "idx_mission_daily_log_template_date")
  @@map("mission_daily_logs")
}

model MissionAssignment {
  id               String          @id @default(cuid()) @db.VarChar(30)
  user_id          String          @db.VarChar(64)
  template_id      String          @db.VarChar(30)
  status           String          @default("pending") @db.VarChar(20)
  assigned_at      DateTime        @default(now())
  completed_at     DateTime?
  progress_current Int             @default(0)
  progress_target  Int             @default(1)
  template         MissionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status], map: "idx_mission_assignments_user_status")
  @@index([template_id], map: "idx_mission_assignments_template")
  @@map("mission_assignments")
}

model UserStreak {
  id               Int       @id @default(autoincrement())
  product_id       String    @db.VarChar(30)
  user_id          String    @db.VarChar(64)
  streak_key       String    @db.VarChar(100)
  count_current    Int       @default(0)
  count_best       Int       @default(0)
  last_occurred_on DateTime? @db.Date
  updated_at       DateTime  @updatedAt
  product          Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id, streak_key])
  @@index([product_id, streak_key], map: "idx_user_streaks_product_key")
  @@map("user_streaks")
}

model BadgeTemplate {
  id                 String      @id @default(cuid()) @db.VarChar(30)
  product_id         String      @db.VarChar(30)
  key                String      @db.VarChar(100)
  name               String      @db.VarChar(200)
  description        String?
  icon               String?
  criteria           Json
  is_active          Boolean     @default(true)
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt
  notify_content_key String?     @db.VarChar(100)
  product            Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user_badges        UserBadge[]

  @@unique([product_id, key])
  @@index([product_id], map: "idx_badge_templates_product")
  @@map("badge_templates")
}

model UserBadge {
  id          Int           @id @default(autoincrement())
  user_id     String        @db.VarChar(64)
  template_id String        @db.VarChar(30)
  earned_at   DateTime      @default(now())
  template    BadgeTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id])
  @@index([user_id], map: "idx_user_badges_user")
  @@index([template_id], map: "idx_user_badges_template")
  @@map("user_badges")
}

model JourneyTemplate {
  id          String   @id @default(cuid()) @db.VarChar(30)
  product_id  String   @db.VarChar(30)
  key         String   @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?
  phases      Json
  transitions Json
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, key])
  @@index([product_id], map: "idx_journey_templates_product")
  @@map("journey_templates")
}

model MessageLog {
  id           Int      @id @default(autoincrement())
  oa_id        Int
  user_id      String   @db.VarChar(64)
  direction    String   @db.VarChar(10)
  type         String   @db.VarChar(20)
  content_text String?
  content_json Json?
  source       String?  @db.VarChar(30)
  source_ref   String?  @db.VarChar(200)
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([oa_id, created_at], map: "idx_message_log_oa_time")
  @@index([user_id, created_at], map: "idx_message_log_user_time")
  @@index([oa_id, user_id, created_at], map: "idx_message_log_oa_user_time")
  @@map("message_log")
}

model UserJourneyPhase {
  id          Int      @id @default(autoincrement())
  product_id  String   @db.VarChar(30)
  user_id     String   @db.VarChar(64)
  journey_key String   @db.VarChar(100)
  phase_key   String   @db.VarChar(100)
  entered_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id, journey_key])
  @@index([product_id, journey_key, phase_key], map: "idx_user_journey_phase")
  @@map("user_journey_phases")
}

model UserAttribute {
  id      Int      @id @default(autoincrement())
  user_id String   @db.VarChar(64)
  key     String   @db.VarChar(100)
  value   String?
  set_at  DateTime @default(now())
  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, key])
  @@index([user_id], map: "idx_user_attributes_user")
  @@index([key, value], map: "idx_user_attributes_key_value")
  @@map("user_attributes")
}

model LineOARichMenuTemplate {
  id                Int      @id @default(autoincrement())
  oa_id             Int
  name              String   @db.VarChar(200)
  zones             Json
  line_rich_menu_id String?  @db.VarChar(100)
  is_active         Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  oa                LineOA   @relation(fields: [oa_id], references: [id], onDelete: Cascade)

  @@index([oa_id], map: "idx_rich_menu_templates_oa")
  @@map("line_oa_rich_menu_template")
}

model CoBlocksScenario {
  id          String       @id @default(cuid())
  oa_id       Int
  name        String
  flow_nodes  Json         @default("[]")
  flow_edges  Json         @default("[]")
  is_active   Boolean      @default(false)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  oa          LineOA       @relation(fields: [oa_id], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@index([oa_id], map: "idx_coblocks_scenarios_oa")
  @@index([is_active], map: "idx_coblocks_scenarios_active")
  @@map("coblocks_scenarios")
}

model Enrollment {
  id          Int              @id @default(autoincrement())
  user_id     String           @db.VarChar(64)
  scenario_id String           @db.VarChar(30)
  enrolled_at DateTime         @default(now())
  status      String           @default("active") @db.VarChar(20)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  scenario    CoBlocksScenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, scenario_id])
  @@index([user_id], map: "idx_enrollment_user")
  @@index([scenario_id, status], map: "idx_enrollment_scenario_status")
  @@map("enrollments")
}

model UserMenuAssignment {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  oa_id       Int
  template_id Int?
  source      String   @db.VarChar(20)
  assigned_at DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, oa_id])
  @@index([oa_id], map: "idx_user_menu_oa")
  @@map("user_menu_assignments")
}

model MessageDelivery {
  id           Int      @id @default(autoincrement())
  user_id      String   @db.VarChar(64)
  scenario_id  String   @db.VarChar(30)
  node_id      String   @db.VarChar(100)
  delivered_at DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, scenario_id, node_id])
  @@index([user_id], map: "idx_message_delivery_user")
  @@map("message_deliveries")
}

model EngagementEvent {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(64)
  event_type  String   @db.VarChar(30)
  payload     String?
  occurred_at DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, occurred_at], map: "idx_engagement_user_time")
  @@index([event_type, occurred_at], map: "idx_engagement_type_time")
  @@map("engagement_events")
}

model DiaryEntry {
  id          String   @id @default(cuid())
  user_id     String   @db.VarChar(64)
  date        DateTime @db.Date
  mood        Int
  sleep       Int
  diary       String?
  ai_feedback String?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, date])
  @@map("diary_entries")
}

model ReliefSession {
  id           String     @id @default(cuid())
  user_id      String     @db.VarChar(64)
  type         ReliefType
  duration_sec Int
  completed_at DateTime   @default(now())
  user         User       @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_relief_sessions_user")
  @@map("relief_sessions")
}

model AssessmentResult {
  id           String   @id @default(cuid())
  user_id      String   @db.VarChar(64)
  result_type  String   @db.VarChar(1)
  scores       Json
  ai_analysis  Json
  face_insight String?
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_assessment_results_user")
  @@map("assessment_results")
}

model UnmatchedIntent {
  id         Int      @id @default(autoincrement())
  user_id    String   @db.VarChar(64)
  oa_id      Int
  product_id String?  @db.VarChar(30)
  agent_id   String?  @db.VarChar(100)
  message    String   @db.VarChar(2000)
  reply      String?
  skill_key  String?  @db.VarChar(100)
  model      String?  @db.VarChar(100)
  latency_ms Int?
  error      String?
  resolved   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([oa_id, created_at(sort: Desc)], map: "idx_unmatched_intents_oa_created")
  @@index([resolved, created_at(sort: Desc)], map: "idx_unmatched_intents_resolved")
  @@index([user_id, created_at(sort: Desc)], map: "idx_unmatched_intents_user_created")
  @@map("unmatched_intents")
}

model menstrual_cycles {
  id              String   @id
  user_id         String   @unique @db.VarChar(64)
  cycle_length    Int      @default(28)
  period_length   Int      @default(5)
  onboarding_done Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime
  users           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model menstrual_daily_logs {
  id         String   @id
  user_id    String   @db.VarChar(64)
  date       DateTime
  data       Json
  created_at DateTime @default(now())
  updated_at DateTime
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date])
  @@index([user_id], map: "idx_daily_logs_user")
}

model menstrual_periods {
  id         String    @id
  user_id    String    @db.VarChar(64)
  start_date DateTime
  end_date   DateTime?
  notes      String?
  created_at DateTime  @default(now())
  updated_at DateTime
  users      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([start_date], map: "idx_periods_start_date")
  @@index([user_id], map: "idx_periods_user")
}

model oa_products {
  oa_id      Int
  product_id String   @db.VarChar(30)
  is_default Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  line_oa    LineOA   @relation(fields: [oa_id], references: [id], onDelete: Cascade)
  products   Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([oa_id, product_id])
  @@index([product_id], map: "idx_oa_products_product")
}

model user_oa_sessions {
  user_id            String   @db.VarChar(64)
  oa_id              Int
  current_product_id String   @db.VarChar(30)
  last_active_at     DateTime @default(now())
  products           Product  @relation(fields: [current_product_id], references: [id], onDelete: Cascade)
  line_oa            LineOA   @relation(fields: [oa_id], references: [id], onDelete: Cascade)
  users              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, oa_id])
  @@index([oa_id, current_product_id], map: "idx_user_oa_sessions_oa_product")
}

enum ReliefType {
  BREATHING
  BODY_SCAN
  SLEEP_QUOTES
}
