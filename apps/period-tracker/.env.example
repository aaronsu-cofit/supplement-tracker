# =============================================================================
# Period Tracker Frontend Environment Configuration
# =============================================================================

# Vite Dev Server Port
VITE_PORT=5173

# Enable Proxy for Local Development
# Set to 'true' to enable Vite proxy (useful for local development)
# Set to any other value (or omit) to disable proxy (useful when using ngrok or direct API URLs)
#
# When enabled (true):
#   - Vite dev server proxies /api/* requests to VITE_API_URL
#   - Useful for local development: VITE_API_URL=http://localhost:4000
#
# When disabled (false, or any other value):
#   - Frontend directly connects to VITE_API_URL
#   - Useful with ngrok: VITE_ENABLE_PROXY=false VITE_API_URL=https://your-ngrok-url
VITE_ENABLE_PROXY=true

# API Base URL
# URL to the Business App backend
#
# Local Development (with proxy):
#   VITE_API_URL="http://localhost:8080"
#
# ngrok Tunnel (without proxy):
#   VITE_ENABLE_PROXY=false
#   VITE_API_URL="https://your-ngrok-subdomain.ngrok.io"
VITE_API_URL="http://localhost:8080"

# LINE LIFF ID
# 從 LINE Developers Console 取得的 LIFF ID
# 只有使用 ?provider=line 時才需要設定此環境變數
#
# 可以透過兩種方式提供 LIFF ID：
# 1. 設定此環境變數（預設值）
# 2. 在 URL 加上參數：?provider=line&liffId=1234567890-abcdefgh
#
# URL 參數的優先權高於環境變數，方便測試不同的 LIFF ID
# 範例: VITE_LIFF_ID="1234567890-abcdefgh"
VITE_LIFF_ID=""

# Enable Eruda Mobile Debugger
# Set to 'true' to enable Eruda for mobile debugging (console, network, storage, etc.)
# Set to 'false' or any other value to disable
# 範例: VITE_ENABLE_ERUDA="true"
VITE_ENABLE_ERUDA="true"
