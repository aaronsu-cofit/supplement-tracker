# GCP config
GCP_PROJECT=your-gcp-project-id
GCP_REGION=asia-east1

# Shared env vars
NEXT_PUBLIC_LOGIN_URL=https://vitera-portal.cofit.me/login
NEXT_PUBLIC_PORTAL_URL=https://vitera-portal.cofit.me

# Portal-specific
NEXT_PUBLIC_ALLOWED_REDIRECT_ORIGINS=https://vitera-wounds.cofit.me,https://vitera-supplements.cofit.me,https://vitera-bones.cofit.me,https://vitera-intimacy.cofit.me,https://vitera-hq.cofit.me

# Per-app LIFF IDs (mapped to NEXT_PUBLIC_LIFF_ID at build time by the deploy script)
