# ─────────────────────────────────────────────────────────────────────────────
# Cloud Run deployment env template
#
# Copy to environment-specific files (not committed to git):
#   cp .env.cloudrun.example .env.cloudrun.staging
#   cp .env.cloudrun.example .env.cloudrun.production
#
# Usage:
#   ./scripts/deploy-frontend-cloudrun.sh portal --env staging
#   ./scripts/deploy-frontend-cloudrun.sh all --env production
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=asia-east1

# ── Backend API URL ───────────────────────────────────────────────────────────
# staging:    https://vitera-backend-staging-xxxx.run.app  (or custom domain)
# production: https://api.cofit.me
NEXT_PUBLIC_API_URL=https://your-backend-url

# ── Portal URLs ───────────────────────────────────────────────────────────────
# staging:    https://vitera-portal-staging-xxxx.run.app
# production: https://vitera-portal.cofit.me
NEXT_PUBLIC_LOGIN_URL=https://your-portal-url/login
NEXT_PUBLIC_PORTAL_URL=https://your-portal-url

# ── Portal: allowed redirect origins after login ─────────────────────────────
# Comma-separated list of all sub-app URLs
NEXT_PUBLIC_ALLOWED_REDIRECT_ORIGINS=https://vitera-wounds-xxxx.run.app,https://vitera-supplements-xxxx.run.app,https://vitera-bones-xxxx.run.app,https://vitera-intimacy-xxxx.run.app,https://vitera-hq-xxxx.run.app

# ── Per-app LIFF IDs ──────────────────────────────────────────────────────────
# Each app maps to NEXT_PUBLIC_LIFF_ID at build time
# staging and production use different LIFF channel IDs
LIFF_ID_WOUNDS=your-liff-id-wounds
LIFF_ID_SUPPLEMENTS=your-liff-id-supplements
LIFF_ID_BONES=your-liff-id-bones
LIFF_ID_INTIMACY=your-liff-id-intimacy
# LIFF_ID_HQ=    # hq doesn't use LINE login
