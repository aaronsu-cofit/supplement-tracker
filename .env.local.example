# ─────────────────────────────────────────────────────────────────────────────
# Local development .env.local template
#
# Copy this file to each app directory:
#   cp .env.local.example apps/portal/.env.local
#   cp .env.local.example apps/wounds/.env.local
#   cp .env.local.example apps/supplements/.env.local
#   cp .env.local.example apps/bones/.env.local
#   cp .env.local.example apps/intimacy/.env.local
#   cp .env.local.example apps/hq/.env.local
#
# Or run: ./scripts/setup-local-env.sh
# ─────────────────────────────────────────────────────────────────────────────

# Backend API (local Express server)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Portal login URL (used by all sub-apps)
NEXT_PUBLIC_LOGIN_URL=http://localhost:3000/login

# Portal URL (used by hq's "back to portal" link)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# Allowed redirect origins after login (portal only)
NEXT_PUBLIC_ALLOWED_REDIRECT_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# LINE LIFF ID for this app — leave empty to skip LIFF init locally
NEXT_PUBLIC_LIFF_ID=
